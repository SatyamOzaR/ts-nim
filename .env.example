# Overrides for local/docker-compose. Default keys are also set in each service Dockerfile
# (except API_KEY / NEXT_PUBLIC_API_KEY — pass those at runtime or in .env).
NEO4J_URI=neo4j+s://YOUR_INSTANCE.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_auradb_password
API_KEY=tsi_demo_key_123

# LLM Provider: "openrouter" (default) or "gemini" for native Google API
LLM_PROVIDER=openrouter
# OpenRouter API key (get free at https://openrouter.ai/keys)
LLM_API_KEY=sk-or-v1-your_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.5-flash

# Only needed if LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here

BACKEND_URL=http://backend:8000
